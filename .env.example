# Local direct-serial configuration for Genesis v1.8 / Farmduino.
# The Pi talks to the stock Farmduino firmware over USB (/dev/ttyACM0).
# No FarmBot Cloud account, MQTT broker, or WiFi credentials are needed.

# If you want to run the UI/API without a live bot, set this to 0.
# FARMBOT_REQUIRED=1

# Serial port override (default shown)
# FARMduino_PORT=/dev/ttyACM0

# General runtime settings
# FARMBOT_ENV=dev
# FARMBOT_LOG_LEVEL=INFO

# Safety limits (defaults shown)
# FARMBOT_MAX_WATER_SECONDS=300
# FARMBOT_MAX_AXIS_X=1900
# FARMBOT_MAX_AXIS_Y=700
# FARMBOT_MAX_AXIS_Z=500

# Backend selection (only direct_serial is supported now)
# WATERING_BACKEND=direct_serial

# Watering/hardware overrides (defaults shown)
# FARMBOT_PUMP_PIN=8

# LLM planner configuration (required for AI planning / assistant tab)
PLANNING_LLM_API_KEY=
# PLANNING_LLM_PROVIDER=openrouter
# PLANNING_LLM_BASE_URL=https://openrouter.ai/api/v1
# PLANNING_LLM_MODEL=ibm-granite/granite-4.1-8b
# PLANNING_LLM_TIMEOUT_S=120
# PLANNING_LLM_TEMPERATURE=0.0

# Optional W&B Weave tracing project
# WEAVE_PROJECT=

# UI / API wiring (defaults shown)
# TWFB_API_URL=http://127.0.0.1:8000
# TWFB_UI_PORT=8501
# TWFB_RESIREG_URL=http://127.0.0.1:8080
# TWFB_CONFIG=configs/dev.yaml
# TWFB_UI_DATA_DIR=data/ui_sessions
